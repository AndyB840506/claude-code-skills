{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -Command \"Get-ChildItem -Recurse -Filter *.json | ForEach-Object { $c = Get-Content $_ -Raw; if ($c[0] -eq [char]0xFEFF) { Set-Content $_ ($c.Substring(1)) -NoNewline } }\""
          }
        ]
      }
    ]
  }
}
